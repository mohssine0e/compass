# Compass AI providers — copy to `backend/.env` and fill in your own keys.
# `.env` is gitignored, so real keys never get committed. These are the ONLY secrets;
# base URLs and model names have sensible defaults in application.properties.
#
# `backend/.env` is loaded automatically at startup (spring-dotenv) — just run:
#   mvn -f backend spring-boot:run
# No manual export needed.

COMPASS_DB_USER=
COMPASS_DB_PASSWORD=
COMPASS_PORT=


# Primary: Groq — get a key at https://console.groq.com  (API Keys → Create)
GROQ_API_KEY=

# Backup: Google Gemini — get a key at https://aistudio.google.com  ("Get API key")
GEMINI_API_KEY=

# Tertiary: NVIDIA's free NIM catalog — a separate quota pool, tried only once both providers
# above fail/run dry. Sign up (no card) at https://build.nvidia.com, open any model card, click
# "Get API Key" — starts with nvapi-.
NVIDIA_API_KEY=

# Search grounding (Phase 7, optional) — grounds roadmap generation in real sources.
# Tried in order with failover: Exa (primary) → Tavily (fallback). Either works alone; without
# any, generation still works, just ungrounded.
# Primary: Exa — get a key at https://dashboard.exa.ai
EXA_API_KEY=
# Fallback: Tavily (1,000 free queries/month) — https://tavily.com
SEARCH_API_KEY=

# --- Optional overrides (only if a default model gets deprecated / rate-limited) ---
# COMPASS_AI_PRIMARY_MODEL=llama-3.3-70b-versatile
# COMPASS_AI_BACKUP_MODEL=gemini-2.0-flash-lite
