# Compass AI providers — copy to `backend/.env` and fill in your own keys.
# `.env` is gitignored, so real keys never get committed. These are the ONLY secrets;
# base URLs and model names have sensible defaults in application.properties.
#
# Load before running the backend, e.g.:
#   export $(grep -v '^#' backend/.env | xargs)
#   mvn -f backend spring-boot:run
# (or set them in your IDE run configuration).

# Primary: Google Gemini — get a key at https://aistudio.google.com  ("Get API key")
GEMINI_API_KEY=

# Backup: Groq — get a key at https://console.groq.com  (API Keys → Create)
GROQ_API_KEY=

# --- Optional overrides (only if a default model gets deprecated) ---
# COMPASS_AI_PRIMARY_MODEL=gemini-2.0-flash
# COMPASS_AI_BACKUP_MODEL=llama-3.3-70b-versatile
