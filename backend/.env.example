# Compass AI providers — copy to `backend/.env` and fill in your own keys.
# `.env` is gitignored, so real keys never get committed. These are the ONLY secrets;
# base URLs and model names have sensible defaults in application.properties.
#
# `backend/.env` is loaded automatically at startup (spring-dotenv) — just run:
#   mvn -f backend spring-boot:run
# No manual export needed.

COMPASS_DB_USER=
COMPASS_DB_PASSWORD=
COMPASS_PORT=


# Two tiers, four providers (Phase 19) — "fast" (tone, clarifying questions, verification
# checks): Groq -> Gemini Flash. "heavy" (outline drafting, module expansion, self-critique):
# Gemini Pro -> NVIDIA NIM. Gemini Flash and Gemini Pro share one key/account but are separate
# quota pools, addressed by model name (see application.properties) — no second Gemini key
# needed.

# fast tier, primary: Groq — get a key at https://console.groq.com  (API Keys → Create)
GROQ_API_KEY=

# fast tier, backup / heavy tier, primary: Google Gemini — get a key at
# https://aistudio.google.com  ("Get API key"). Powers both gemini-2.0-flash (fast) and
# gemini-2.5-pro (heavy).
GEMINI_API_KEY=

# heavy tier, backup/last-resort: NVIDIA's free NIM catalog — a separate quota pool, tried only
# once Gemini Pro also fails/runs dry. Sign up (no card) at https://build.nvidia.com, open any
# model card, click "Get API Key" — starts with nvapi-.
NVIDIA_API_KEY=




